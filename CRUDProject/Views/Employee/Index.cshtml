@model List<CRUDProject.Models.Domain.Employee>


@{
}



<div class="hero-section">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1 class="display-5 fw-bold">CRUD Costumer System</h1>
        <h2>Udviklet med MVC .NET, C#, </h2>
        <h6>Viser mine færdigheder med at hente, redigere og slettes data fra en medarbejderdatabase som er microsoft sql. </h6>
        <h6>Databasen er oprettet med entity framework.  </h6>
        
    </div>
</div>

<br />
<br />

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Navn</th>
            <th>Email</th>
            <th>Løn</th>
            <th>Personnummer</th>
            <th>Afdeling</th>
            <th></th>


        </tr>

    </thead>

    <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.Id</td>
                <td>@employee.Navn</td>
                <td>@employee.Email</td>
                <td>@employee.Løn</td>
                <td>@employee.PersonNummer.ToString("dd-MM-yyyy")</td>
                <td>@employee.Afdeling</td>
                <td>
                    <a asp-controller="Employee" asp-action="Edit" asp-route-id="@employee.Id">Edit</a>
                </td>
            </tr>
    }

    </tbody>

</table>
