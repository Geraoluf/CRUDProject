@model List<CRUDProject.Models.Domain.Employee>


@{
}

<h1>Medarbejder</h1>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Navn</th>
            <th>Email</th>
            <th>Løn</th>
            <th>Personnummer</th>
            <th>Afdeling</th>
            <th></th>


        </tr>

    </thead>

    <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.Id</td>
                <td>@employee.Navn</td>
                <td>@employee.Email</td>
                <td>@employee.Løn</td>
                <td>@employee.PersonNummer.ToString("dd-MM-yyyy")</td>
                <td>@employee.Afdeling</td>
                <td>
                    <a asp-controller="Employee" asp-action="Edit" asp-route-id="@employee.Id">vis</a>
                </td>
            </tr>
    }

    </tbody>

</table>
