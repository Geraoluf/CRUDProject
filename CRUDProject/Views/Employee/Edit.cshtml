@using CRUDProject.Models.ViewModels
@model DetailsViewModel
@{
}




<h1> Detaljer om medarbejdere </h1>
<form method="post" asp-action="Edit" asp-controller="Employee" class="mt-5">


    <div class="mb-3">
        <label for="" class="form-label">Medarbejder Id</label>
        <input type="text" class="form-control" asp-for="Id" readonly />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Navn</label>
        <input type="text" class="form-control" asp-for="Navn" />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Email</label>
        <input type="email" class="form-control" asp-for="Email" />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Løn</label>
        <input type="number" class="form-control" asp-for="Løn" />
    </div>

    <div class="mb-3">
        <label for="" class="form-label">Personnummer</label>
        <input type="date" class="form-control" asp-for="PersonNummer" />
    </div>


    <div class="mb-3">
        <label for="" class="form-label">Afdeling</label>
        <input type="text" class="form-control" asp-for="Afdeling" />
    </div>

    <form method="post" class="mt-5">
       

        <button type="submit" class="btn btn-primary"
                asp-action="Edit" asp-controller="Employee">
            Save
        </button>

        <button type="submit" class="btn btn-danger ms-3"
                asp-action="Delete" asp-controller="Employee">
            Delete
        </button>

        <button type="submit" class="btn btn-success ms-3" 
        asp-action="Back" asp-controller="Employee"
        >Go Back</button>
    </form>

</form>


